{
  "name": "iphone-price-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "start": "pnpm --filter @repo/worker start",
    "dev:web": "turbo dev --filter=@repo/web",
    "dev:worker": "turbo dev --filter=@repo/worker",
    "build:web": "turbo build --filter=@repo/web",
    "build:worker": "turbo build --filter=@repo/worker",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "prisma": "^6.3.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0"
  },
  "packageManager": "pnpm@9.15.0"
}
