# ---- Database (Neon PostgreSQL) ----
DATABASE_URL="postgresql://user:password@host:5432/iphone_tracker?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/iphone_tracker?sslmode=require"

# ---- Worker (Railway) ----
SYNC_INTERVAL_MS="21600000"   # 6 saat
USE_MOCK_PROVIDERS="false"    # "true" ise gerçek scrape yerine mock veri üretir

# ---- Web (Railway) ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
WORKER_URL="http://localhost:3001"          # Internal Railway URL for worker

# ---- Optional: Future Notifications ----
