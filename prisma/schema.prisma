generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Ürün Ailesi (iPhone 15, iPhone 17 Pro Max vb.) ─────────────
model ProductFamily {
  id        String   @id @default(cuid())
  brand     String   @default("Apple")
  name      String   @unique // "iPhone 15 Pro Max"
  slug      String   @unique // "iphone-15-pro-max"
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants   ProductVariant[]
  alertRules AlertRule[]

  @@index([slug])
}

// ─── Ürün Varyantı (model + renk + depolama) ────────────────────
model ProductVariant {
  id             String   @id @default(cuid())
  familyId       String
  color          String   // "Natural Titanium", "Black", "Blue"
  storageGb      Int      // 128, 256, 512, 1024
  normalizedName String   // "iPhone 15 Pro Max 256GB Natural Titanium"
  slug           String   @unique // "iphone-15-pro-max-256gb-natural-titanium"
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  family     ProductFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  listings   Listing[]
  alertRules AlertRule[]

  @@unique([familyId, color, storageGb])
  @@index([familyId])
  @@index([slug])
  @@index([storageGb])
  @@index([color])
}

// ─── Satış Siteleri ──────────────────────────────────────────────
model Retailer {
  id        String   @id @default(cuid())
  name      String   @unique // "Hepsiburada", "Trendyol", "N11", "Amazon"
  slug      String   @unique // "hepsiburada"
  baseUrl   String   // "https://www.hepsiburada.com"
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  lastBlockedAt       DateTime?
  consecutiveFailures Int       @default(0)
  blockedCount        Int       @default(0)

  listings  Listing[]
  syncJobs  SyncJob[]
}

// ─── Listing (bir varyantın bir sitedeki ilanı) ──────────────────
model Listing {
  id                  String    @id @default(cuid())
  variantId           String
  retailerId          String
  retailerProductTitle String?  // Sitenin kendi ürün başlığı
  externalId          String?   // Sitedeki ürün ID'si
  productUrl          String    // Direkt ürün linki
  imageUrl            String?
  currentPrice        Float?    // Son gözlemlenen fiyat
  previousPrice       Float?    // Bir önceki fiyat
  lowestPrice         Float?    // Tarihsel en düşük
  highestPrice        Float?    // Tarihsel en yüksek
  sellerName          String?   // Marketplace satıcı adı
  stockStatus         StockStatus @default(IN_STOCK)
  isDeal              Boolean   @default(false)  // Fırsat olarak işaretli mi
  dealScore           Float?    // Fırsat puanı (0-100)
  isActive            Boolean   @default(true)
  lastSeenAt          DateTime?
  lastCheckedAt       DateTime?
  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  lastBlockedAt       DateTime?
  // Parser / confidence
  isVerified          Boolean   @default(false)
  confidenceScore     Float?    // 0-1 parse confidence
  parserHealth        String?   // ok, degraded, failing
  // Fallback discovery metadata
  discoverySource       String?   // "direct", "akakce", "cimri", "epey", "enuygun"
  discoveryConfidence   Float?    // 0-1 match confidence
  resolvedViaFallback   Boolean  @default(false)
  lastResolvedAt        DateTime?
  lastResolvedBySource  String?   // which discovery source last resolved this
  lastResolvedRetailerUrl String? // URL that was resolved via fallback
  lastFallbackFailureAt DateTime? // when the last fallback attempt failed
  // Telegram notification tracking
  lastNotifiedPrice   Float?    // Son bildirim gönderilen fiyat
  notificationSentAt  DateTime? // Son bildirim zamanı
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  retailer        Retailer       @relation(fields: [retailerId], references: [id], onDelete: Cascade)
  priceSnapshots  PriceSnapshot[]
  dealEvents      DealEvent[]
  alertEvents     AlertEvent[]

  @@unique([variantId, retailerId])
  @@index([variantId])
  @@index([retailerId])
  @@index([currentPrice])
  @@index([isDeal])
  @@index([lastSeenAt])
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  LIMITED
  UNKNOWN
}

// ─── Fiyat Snapshot'ı ────────────────────────────────────────────
model PriceSnapshot {
  id              String   @id @default(cuid())
  listingId       String
  observedPrice   Float
  previousPrice   Float?
  currency        String   @default("TRY")
  changePercent   Float?   // Yüzdesel değişim
  changeAmount    Float?   // Tutar olarak değişim
  source          String?  // "direct", "fallback", "manual"
  strategyUsed    String?  // hangi scrape stratejisi kullanıldı
  parseConfidence Float?   // 0-1 parse güvenilirliği
  observedAt      DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([observedAt])
  @@index([listingId, observedAt])
  @@index([changePercent])
}

// ─── Fırsat/Deal Olayları ────────────────────────────────────────
model DealEvent {
  id                  String        @id @default(cuid())
  listingId           String
  variantId           String
  retailerId          String
  eventType           DealEventType
  oldPrice            Float?
  newPrice            Float
  dropAmount          Float?
  dropPercent         Float?
  basis               String?       // "30d_avg", "all_time_low", "cross_retailer", etc.
  severity            String        @default("info")  // info, notable, significant, critical
  isNewAllTimeLow     Boolean       @default(false)
  isBelowAverage      Boolean       @default(false)
  isSuspiciousDiscount Boolean      @default(false)
  suspiciousReason    String?       // neden şüpheli
  detectedAt          DateTime      @default(now())

  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([variantId])
  @@index([retailerId])
  @@index([eventType])
  @@index([detectedAt])
  @@index([severity])
}

enum DealEventType {
  PRICE_DROP
  ALL_TIME_LOW
  MONTHLY_LOW
  WEEKLY_LOW
  DAILY_LOW
  BELOW_AVERAGE
  CROSS_RETAILER_LOW
  SUDDEN_DROP
  SUSPICIOUS_DISCOUNT
}

// ─── Fiyat Alarm Kuralları ───────────────────────────────────────
model AlertRule {
  id            String    @id @default(cuid())
  variantId     String?   // Varyant bazlı alarm
  familyId      String?   // Aile bazlı alarm (tüm varyantlara uygulanır)
  retailerSlug  String?   // Belirli bir retailer ile sınırla (opsiyonel)
  type          AlertType
  threshold     Float?    // Hedef fiyat veya yüzde eşiği
  isActive      Boolean   @default(true)
  lastTriggered DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  variant  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  family   ProductFamily?  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  events   AlertEvent[]

  @@index([variantId])
  @@index([familyId])
  @@index([isActive])
}

enum AlertType {
  PRICE_DROP_PERCENT // Yüzdesel düşüş (ör: %5+)
  PRICE_BELOW        // Belirli bir fiyatın altı
  NEW_LOWEST         // Yeni en düşük fiyat
  CROSS_RETAILER     // Diğer sitelere göre en ucuz
}

// ─── Alarm Olayları ──────────────────────────────────────────────
model AlertEvent {
  id           String       @id @default(cuid())
  alertRuleId  String
  listingId    String?
  alertType    AlertType    // Trigger eden alarm tipi
  triggerReason String      // İnsan okunabilir açıklama
  oldPrice     Float?
  newPrice     Float?
  dropPercent  Float?
  isRead       Boolean      @default(false)
  channel      AlertChannel @default(IN_APP)
  triggeredAt  DateTime     @default(now())

  alertRule AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  listing   Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([alertRuleId])
  @@index([listingId])
  @@index([isRead])
  @@index([triggeredAt])
}

enum AlertChannel {
  IN_APP
  TELEGRAM
  EMAIL
  WHATSAPP
}

// ─── Telegram Aboneleri ──────────────────────────────────────────
model TelegramSubscriber {
  id        String   @id @default(cuid())
  chatId    String   @unique  // Telegram chat ID
  username  String?           // @username
  firstName String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// ─── Telegram Bildirim Geçmişi ──────────────────────────────────
model NotificationLog {
  id            String             @id @default(cuid())
  messageType   NotificationMsgType
  status        NotificationStatus
  productName   String?
  retailer      String?
  oldPrice      Float?
  newPrice      Float?
  dropPercent   Float?
  messageText   String?
  sentTo        Int                @default(0) // kaç kişiye gönderildi
  failedTo      Int                @default(0)
  errorMessage  String?
  listingId     String?
  createdAt     DateTime           @default(now())

  @@index([createdAt])
  @@index([messageType])
  @@index([status])
}

enum NotificationMsgType {
  PRICE_DROP
  ALL_TIME_LOW
  TEST_MESSAGE
}

enum NotificationStatus {
  SENT
  PARTIAL
  FAILED
  SKIPPED
}

// ─── Senkronizasyon İşleri ───────────────────────────────────────
model SyncJob {
  id             String     @id @default(cuid())
  retailerId     String?
  status         SyncStatus @default(PENDING)
  startedAt      DateTime?
  finishedAt     DateTime?
  itemsScanned   Int        @default(0) // Taranan toplam öğe
  itemsMatched   Int        @default(0) // Eşleşen / güncellenen öğe
  dealsFound     Int        @default(0) // Tespit edilen fırsat sayısı
  successCount   Int        @default(0)
  failureCount   Int        @default(0)
  blockedCount   Int        @default(0)
  durationMs     Int?
  lastErrorMessage String?
  errors         String?    // JSON hata logları
  createdAt      DateTime   @default(now())

  retailer Retailer? @relation(fields: [retailerId], references: [id])

  @@index([status])
  @@index([createdAt])
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─── Kullanıcı (ilerisi için) ────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  ADMIN
  VIEWER
}
