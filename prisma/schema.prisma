generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Ürün Ailesi (iPhone 15, iPhone 17 Pro Max vb.) ─────────────
model ProductFamily {
  id        String   @id @default(cuid())
  brand     String   @default("Apple")
  name      String   @unique // "iPhone 15 Pro Max"
  slug      String   @unique // "iphone-15-pro-max"
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants   ProductVariant[]
  alertRules AlertRule[]

  @@index([slug])
}

// ─── Ürün Varyantı (model + renk + depolama) ────────────────────
model ProductVariant {
  id             String   @id @default(cuid())
  familyId       String
  color          String   // "Natural Titanium", "Black", "Blue"
  storageGb      Int      // 128, 256, 512, 1024
  normalizedName String   // "iPhone 15 Pro Max 256GB Natural Titanium"
  slug           String   @unique // "iphone-15-pro-max-256gb-natural-titanium"
  imageUrl       String?
  isActive       Boolean  @default(true)
  // Global arbitrage fields
  globalGroupId      String?   // slugify(brand+model+storage) e.g. "iphone-15-pro-max-256gb"
  semanticColorGroup String?   // "dark", "light", "blue", "natural", etc.
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  family     ProductFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  listings   Listing[]
  alertRules AlertRule[]
  priceAnalytics VariantPriceAnalytics?

  @@unique([familyId, color, storageGb])
  @@index([familyId])
  @@index([slug])
  @@index([storageGb])
  @@index([color])
  @@index([globalGroupId])
}

// ─── Satış Siteleri ──────────────────────────────────────────────
model Retailer {
  id        String   @id @default(cuid())
  name      String   @unique // "Hepsiburada", "Trendyol", "N11", "Amazon"
  slug      String   @unique // "hepsiburada"
  baseUrl   String   // "https://www.hepsiburada.com"
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  lastBlockedAt       DateTime?
  consecutiveFailures Int       @default(0)
  blockedCount        Int       @default(0)

  // User-feedback driven score: 0..1. Increment on "ALABİLDİM", decrement on "STOK YOK".
  // Used as a secondary ranking signal in deal detection.
  confidenceScore     Float     @default(0.5)

  listings  Listing[]
  syncJobs  SyncJob[]
}

// ─── Listing (bir varyantın bir sitedeki ilanı) ──────────────────
model Listing {
  id                  String    @id @default(cuid())
  variantId           String
  retailerId          String
  retailerProductTitle String?  // Sitenin kendi ürün başlığı
  externalId          String?   // Sitedeki ürün ID'si
  productUrl          String    // Direkt ürün linki
  imageUrl            String?
  currentPrice        Float?    // Son gözlemlenen fiyat
  previousPrice       Float?    // Bir önceki fiyat
  lowestPrice         Float?    // Tarihsel en düşük
  highestPrice        Float?    // Tarihsel en yüksek
  sellerName          String?   // Marketplace satıcı adı
  stockStatus         StockStatus @default(IN_STOCK)
  isDeal              Boolean   @default(false)  // Fırsat olarak işaretli mi
  dealScore           Float?    // Fırsat puanı (0-100)
  isActive            Boolean   @default(true)
  lastSeenAt          DateTime?
  lastCheckedAt       DateTime?
  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  lastBlockedAt       DateTime?
  // Parser / confidence
  isVerified          Boolean   @default(false)
  confidenceScore     Float?    // 0-1 parse confidence
  parserHealth        String?   // ok, degraded, failing
  // Fallback discovery metadata
  discoverySource       String?   // "direct", "akakce", "cimri", "epey", "enuygun"
  discoveryConfidence   Float?    // 0-1 match confidence
  resolvedViaFallback   Boolean  @default(false)
  lastResolvedAt        DateTime?
  lastResolvedBySource  String?   // which discovery source last resolved this
  lastResolvedRetailerUrl String? // URL that was resolved via fallback
  lastFallbackFailureAt DateTime? // when the last fallback attempt failed
  // Telegram notification tracking
  lastNotifiedPrice   Float?    // Son bildirim gönderilen fiyat
  notificationSentAt  DateTime? // Son bildirim zamanı
  // Pulse Protocol (cycle-based dynamic backoff)
  consecutiveFailures Int       @default(0)
  skipUntilCycle      Int       @default(0)  // Absolute scheduler cycle to wait for (0 = ready)
  isFresh             Boolean   @default(false) // True if last scrape succeeded — replaces lastSeenAt window check
  // Ghost flag from Telegram feedback: when community votes "stok yok / hatalı" ≥3 times
  // within 10 minutes, ghostUntil is set. generateTasks() skips ghosted listings.
  ghostUntil          DateTime?
  ghostReason         String?   // "community-vote", "admin", etc.
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  retailer        Retailer       @relation(fields: [retailerId], references: [id], onDelete: Cascade)
  priceSnapshots  PriceSnapshot[]
  dealEvents      DealEvent[]
  alertEvents     AlertEvent[]
  priceDailyStats PriceDailyStats[]

  @@unique([variantId, retailerId])
  @@index([variantId])
  @@index([retailerId])
  @@index([currentPrice])
  @@index([isDeal])
  @@index([lastSeenAt])
  // Composite indexes for hot queries
  @@index([isDeal, stockStatus, dealScore])      // deals API + dashboard topDeals
  @@index([variantId, isActive, currentPrice])   // market snapshot + best-by-storage
  @@index([isDeal, lastSeenAt])                  // dashboard 24h deal count
  // V2 additions
  @@index([isDeal, lastSeenAt, dealScore])       // /api/deals deep sort
  @@index([variantId, retailerId, isActive])     // snapshot + cross-retailer lookup
  // Pulse Protocol queue filter
  @@index([isActive, skipUntilCycle])
  @@index([isFresh])
  @@index([ghostUntil])
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  LIMITED
  UNKNOWN
}

// ─── Fiyat Snapshot'ı ────────────────────────────────────────────
model PriceSnapshot {
  id              String   @id @default(cuid())
  listingId       String
  observedPrice   Float
  previousPrice   Float?
  currency        String   @default("TRY")
  changePercent   Float?   // Yüzdesel değişim
  changeAmount    Float?   // Tutar olarak değişim
  source          String?  // "direct", "fallback", "manual"
  strategyUsed    String?  // hangi scrape stratejisi kullanıldı
  parseConfidence Float?   // 0-1 parse güvenilirliği
  observedAt      DateTime @default(now())
  lastSeenAt      DateTime @default(now()) // Updated when same price is observed again
  isSignificant   Boolean  @default(false) // Protected from cleanup (big drops, etc.)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([observedAt])
  @@index([listingId, observedAt])
  @@index([changePercent])
  @@index([isSignificant])
  @@index([observedAt, changePercent])            // biggest-drops API query
  // V2 additions
  @@index([listingId, observedAt, changePercent]) // biggest-drops by listing
  @@index([listingId, isSignificant, observedAt]) // prune candidate scan
}

// ─── Fırsat/Deal Olayları ────────────────────────────────────────
model DealEvent {
  id                  String        @id @default(cuid())
  listingId           String
  variantId           String
  retailerId          String
  eventType           DealEventType
  oldPrice            Float?
  newPrice            Float
  dropAmount          Float?
  dropPercent         Float?
  basis               String?       // "30d_avg", "all_time_low", "cross_retailer", etc.
  severity            String        @default("info")  // info, notable, significant, critical
  isNewAllTimeLow     Boolean       @default(false)
  isBelowAverage      Boolean       @default(false)
  isSuspiciousDiscount Boolean      @default(false)
  suspiciousReason    String?       // neden şüpheli
  detectedAt          DateTime      @default(now())

  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([variantId])
  @@index([retailerId])
  @@index([eventType])
  @@index([detectedAt])
  @@index([severity])
  @@index([listingId, eventType, detectedAt])    // deal dedup check
}

enum DealEventType {
  PRICE_DROP
  ALL_TIME_LOW
  MONTHLY_LOW
  WEEKLY_LOW
  DAILY_LOW
  BELOW_AVERAGE
  CROSS_RETAILER_LOW
  SUDDEN_DROP
  SUSPICIOUS_DISCOUNT
}

// ─── Fiyat Alarm Kuralları ───────────────────────────────────────
model AlertRule {
  id            String    @id @default(cuid())
  variantId     String?   // Varyant bazlı alarm
  familyId      String?   // Aile bazlı alarm (tüm varyantlara uygulanır)
  retailerSlug  String?   // Belirli bir retailer ile sınırla (opsiyonel)
  type          AlertType
  threshold     Float?    // Hedef fiyat veya yüzde eşiği
  isActive      Boolean   @default(true)
  lastTriggered DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  variant  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  family   ProductFamily?  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  events   AlertEvent[]

  @@index([variantId])
  @@index([familyId])
  @@index([isActive])
}

enum AlertType {
  PRICE_DROP_PERCENT // Yüzdesel düşüş (ör: %5+)
  PRICE_BELOW        // Belirli bir fiyatın altı
  NEW_LOWEST         // Yeni en düşük fiyat
  CROSS_RETAILER     // Diğer sitelere göre en ucuz
}

// ─── Alarm Olayları ──────────────────────────────────────────────
model AlertEvent {
  id           String       @id @default(cuid())
  alertRuleId  String
  listingId    String?
  alertType    AlertType    // Trigger eden alarm tipi
  triggerReason String      // İnsan okunabilir açıklama
  oldPrice     Float?
  newPrice     Float?
  dropPercent  Float?
  isRead       Boolean      @default(false)
  channel      AlertChannel @default(IN_APP)
  triggeredAt  DateTime     @default(now())

  alertRule AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  listing   Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([alertRuleId])
  @@index([listingId])
  @@index([isRead])
  @@index([triggeredAt])
  @@index([isRead, triggeredAt])                 // dashboard unread alerts
}

enum AlertChannel {
  IN_APP
  TELEGRAM
  EMAIL
  WHATSAPP
}

// ─── Telegram Aboneleri ──────────────────────────────────────────
model TelegramSubscriber {
  id        String   @id @default(cuid())
  chatId    String   @unique  // Telegram chat ID
  username  String?           // @username
  firstName String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// ─── Telegram Bildirim Geçmişi ──────────────────────────────────
model NotificationLog {
  id            String             @id @default(cuid())
  messageType   NotificationMsgType
  status        NotificationStatus
  productName   String?
  retailer      String?
  oldPrice      Float?
  newPrice      Float?
  dropPercent   Float?
  messageText   String?
  sentTo        Int                @default(0) // kaç kişiye gönderildi
  failedTo      Int                @default(0)
  errorMessage  String?
  listingId     String?

  // ── Yapısal alanlar (filtreleme + analiz için) ──
  bakiScore         Int?      // Baki-Quant skoru
  arbScore          Int?      // Arbitraj motorunun skoru
  tier              String?   // 'GLOBAL_FLOOR' | 'FAMILY_ARBITRAGE'
  isAllTimeLow      Boolean   @default(false)
  marketFloorAtSend Float?    // Mesaj anındaki global taban
  groupAtlAtSend    Float?    // Mesaj anındaki grup ATL
  variantId         String?
  rejectionReason   String?   // SKIPPED satırlar için
  failedEmirs       Int[]     // Reddedilen Emir ID'leri

  createdAt     DateTime           @default(now())

  @@index([createdAt])
  @@index([messageType])
  @@index([status])
  @@index([isAllTimeLow])
  @@index([variantId])
}

enum NotificationMsgType {
  PRICE_DROP
  ALL_TIME_LOW
  GLOBAL_FLOOR
  FAMILY_ARBITRAGE
  TEST_MESSAGE
  HEALTH_REPORT
  DEAL_ALERT
}

enum NotificationStatus {
  SENT
  PARTIAL
  FAILED
  SKIPPED
}

// ─── AutoTuner History (Faz 2: AIMD telemetri kalıcılığı) ──────
// Leader replica restart'ında in-memory history kaybolur. Bu tablo
// retrospektif analiz, model eğitimi ve UI time-range navigation için.
// Insert sıklığı: dakikada 1 (her tick).
model AutoTunerHistory {
  id              String   @id @default(cuid())
  ts              DateTime @default(now())
  state           String   // CRUISING | OVERCLOCKING | THROTTLING | DISABLED | STARVED | PAUSED
  activeMode      String   // auto | god | aggressive | balanced | safe | pause
  concurrency     Int
  delayMinMs      Int
  scrapesPerMin   Int
  p95LatencyMs    Int
  errorRate       Float
  errors429       Int      @default(0)
  errors403       Int      @default(0)
  errors503       Int      @default(0)
  sampleCount     Int      @default(0)
  cleanStreak     Int      @default(0)
  action          String?  // "BRAKE conc 8→4", "OVERCLOCK conc 6→8"
  leaderWorkerId  String?

  @@index([ts])
  @@index([state])
}

// ─── Senkronizasyon İşleri ───────────────────────────────────────
model SyncJob {
  id             String     @id @default(cuid())
  retailerId     String?
  status         SyncStatus @default(PENDING)
  startedAt      DateTime?
  finishedAt     DateTime?
  itemsScanned   Int        @default(0) // Taranan toplam öğe
  itemsMatched   Int        @default(0) // Eşleşen / güncellenen öğe
  dealsFound     Int        @default(0) // Tespit edilen fırsat sayısı
  successCount   Int        @default(0)
  failureCount   Int        @default(0)
  blockedCount   Int        @default(0)
  durationMs     Int?
  lastErrorMessage String?
  errors         String?    // JSON hata logları
  createdAt      DateTime   @default(now())

  retailer Retailer? @relation(fields: [retailerId], references: [id])
  tasks    ScrapeTask[]

  @@index([status])
  @@index([createdAt])
  @@index([status, finishedAt])                  // last completed sync lookup
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─── Kullanıcı (ilerisi için) ────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  ADMIN
  VIEWER
}

// ─── Uygulama Ayarları (singleton — tek satır) ──────────────────
model AppSettings {
  id                    String   @id @default("default")

  // Telegram bildirim eşikleri
  notifyDropPercent     Float    @default(1)     // Min % düşüş (ör: 1 = %1)
  notifyDropAmount      Float    @default(100)   // Min TL düşüş
  notifyCooldownMinutes Int      @default(240)   // Aynı listing için bekleme süresi (dk)
  notifyAllTimeLow      Boolean  @default(true)  // Tüm zamanların en düşüğünde bildir
  notifyEnabled         Boolean  @default(true)  // Bildirimleri aç/kapa (master switch)

  // Bildirim filtreleri
  notifyMinPrice        Float?                   // Bu fiyatın altındaki düşüşleri bildir (null = sınırsız)
  notifyMaxPrice        Float?                   // Bu fiyatın üstündeki düşüşleri bildir (null = sınırsız)

  // Bildirim tipleri aç/kapa
  notifyPriceDrop       Boolean  @default(true)  // Fiyat düşüşü bildirimleri
  notifySmartDeal       Boolean  @default(true)  // Akıllı fırsat bildirimleri
  notifyDailyReport     Boolean  @default(true)  // Günlük sağlık raporu

  // Akıllı fırsat ayarları
  smartDealMinScore       Int    @default(80)    // Minimum skor (0-100) — sadece bu ve üstü gönderilir
  smartDealCooldownMin    Int    @default(60)    // Aynı listing için akıllı fırsat bekleme süresi (dk)

  // Bildirim zamanlama detayı
  notifyTimingBreakdown   Boolean @default(false) // Bildirimde zamanlama detayını göster

  updatedAt             DateTime @updatedAt
}

// ─── Worker Konfigürasyonu (singleton — tek satır) ──────────────
model WorkerConfig {
  id                    String   @id @default("default")

  // Sync interval
  syncIntervalMinMs     Int      @default(60000)     // Min sync aralığı (ms)
  syncIntervalMaxMs     Int      @default(3600000)   // Max sync aralığı (ms)

  // Request pacing
  requestDelayMinMs     Int      @default(1500)      // Min istek arası bekleme
  requestDelayMaxMs     Int      @default(3000)      // Max istek arası bekleme
  jitterPercent         Int      @default(30)        // Jitter yüzdesi (0-100)

  // Concurrency
  globalConcurrency     Int      @default(1)         // Aynı anda toplam istek
  providerConcurrency   Int      @default(1)         // Provider başına eşzamanlılık

  // Retry & cooldown
  maxRetries            Int      @default(2)         // İstek başına max tekrar
  cooldownMultiplier    Float    @default(1.5)       // Cooldown escalation çarpanı
  blockCooldownMinutes  Int      @default(10)        // Bloklandıktan sonra bekleme (dk)

  // Mode
  activeMode            String   @default("balanced") // safe, balanced, aggressive, god

  updatedAt             DateTime @updatedAt
}

// ─── Provider Metrikleri (provider başına) ───────────────────────
model ProviderMetrics {
  id                    String   @id @default(cuid())
  retailerSlug          String   @unique
  
  // Success/failure
  totalRequests         Int      @default(0)
  successCount          Int      @default(0)
  failureCount          Int      @default(0)
  blockedCount          Int      @default(0)       // 403
  rateLimitCount        Int      @default(0)       // 429
  timeoutCount          Int      @default(0)

  // Response times (ms)
  avgResponseTimeMs     Float    @default(0)
  p95ResponseTimeMs     Float    @default(0)
  lastResponseTimeMs    Float    @default(0)

  // Health scores (0-100)
  healthScore           Float    @default(100)
  riskScore             Float    @default(0)       // 0=safe, 100=very risky

  // Circuit breaker
  circuitState          String   @default("closed") // closed, open, half_open
  circuitOpenedAt       DateTime?
  consecutiveFailures   Int      @default(0)

  // Rates (rolling window)
  successRate5m         Float    @default(100)      // Son 5dk başarı oranı (%)
  blockRate5m           Float    @default(0)        // Son 5dk blok oranı (%)
  avgLatency5m          Float    @default(0)        // Son 5dk ortalama latency

  // Timestamps
  lastSuccessAt         DateTime?
  lastFailureAt         DateTime?
  lastBlockedAt         DateTime?
  lastRateLimitAt       DateTime?

  // Recommendations
  recommendedDelayMs    Int      @default(2000)
  recommendedConcurrency Int     @default(1)

  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())

  @@index([retailerSlug])
  @@index([healthScore])
  @@index([riskScore])
}

// ─── Market Correction Events ────────────────────────────────────
model MarketCorrectionEvent {
  id              String   @id @default(cuid())
  globalGroupId   String   // which product group
  providersDropped Int     @default(0)  // how many providers dropped
  totalProviders   Int     @default(0)  // total tracked providers
  dropPercent      Float   @default(0)  // average drop %
  windowHours      Int     @default(12) // detection window
  detectedAt       DateTime @default(now())

  @@index([globalGroupId])
  @@index([detectedAt])
}

// ─── Distributed Lock (leader election) ─────────────────────────
model DistributedLock {
  id          String   @id              // e.g. "scheduler", "telegram-poll"
  holder      String                    // instance UUID holding the lock
  acquiredAt  DateTime @default(now())
  expiresAt   DateTime                  // auto-expire if holder crashes
  renewedAt   DateTime @default(now())
}

// ─── Scrape Task Queue (distributed work items) ─────────────────
model ScrapeTask {
  id            String          @id @default(cuid())
  syncJobId     String
  listingId     String
  retailerSlug  String
  variantLabel  String
  productUrl    String
  priority      Int             @default(0)     // higher = dequeue first

  status        ScrapeTaskStatus @default(PENDING)
  lockedBy      String?                         // worker instance id
  lockedAt      DateTime?
  completedAt   DateTime?

  // Result
  resultPrice   Float?
  resultStatus  String?                         // success, failure, blocked, skipped
  errorMessage  String?
  responseTimeMs Int?

  createdAt     DateTime        @default(now())

  syncJob       SyncJob         @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@index([status, priority])
  @@index([syncJobId])
  @@index([retailerSlug, status])
  @@index([lockedBy])
  @@index([lockedAt])
  @@index([syncJobId, status])                   // getTaskQueueStats (5 counts → groupBy)
}

enum ScrapeTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  SKIPPED
}

// ─── Worker Heartbeat (cluster identity & monitoring) ────────────
model WorkerHeartbeat {
  id              String   @id              // worker instance UUID
  hostname        String
  startedAt       DateTime @default(now())
  lastHeartbeatAt DateTime @default(now())
  status          String   @default("idle") // idle, busy, stopping
  currentTaskId   String?
  tasksCompleted  Int      @default(0)
  tasksFailed     Int      @default(0)
  tasksSkipped    Int      @default(0)
  avgTaskTimeMs   Float    @default(0)
  concurrency     Int      @default(5)

  @@index([lastHeartbeatAt])
  @@index([status])
}

// ─── Provider Rate Limits (distributed throttling) ───────────────
model ProviderRateLimit {
  id                String   @id              // retailer slug
  maxPerMinute      Int      @default(20)
  currentCount      Int      @default(0)
  windowStart       DateTime @default(now())
  maxConcurrency    Int      @default(3)
  currentConcurrency Int     @default(0)
  updatedAt         DateTime @updatedAt

  @@index([id])
}

// ─── Scrape Health Snapshot (hourly aggregated provider stats) ───
model ScrapeHealthSnapshot {
  id              String   @id @default(cuid())
  retailerSlug    String
  periodStart     DateTime // start of the 1-hour window
  periodEnd       DateTime
  totalAttempts   Int      @default(0)
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  blockedCount    Int      @default(0)
  timeoutCount    Int      @default(0)
  avgResponseMs   Float    @default(0)
  p95ResponseMs   Float    @default(0)
  successRate     Float    @default(0) // 0-100
  listingsUpdated Int      @default(0)
  listingsFailed  Int      @default(0)
  httpStatusCodes String?  // JSON: {"200":45,"403":3,"429":1}
  createdAt       DateTime @default(now())

  @@unique([retailerSlug, periodStart])
  @@index([retailerSlug])
  @@index([periodStart])
  @@index([createdAt])
}

// ─── Daily Scrape Report (sent to Telegram) ─────────────────────
model DailyScrapeReport {
  id              String   @id @default(cuid())
  reportDate      DateTime @unique // YYYY-MM-DD
  totalListings   Int      @default(0)
  updatedToday    Int      @default(0)
  failedToday     Int      @default(0)
  staleListings   Int      @default(0) // not updated in 12h+
  providerSummary String?  // JSON array of per-provider stats
  topFailures     String?  // JSON array of top failure reasons
  sentToTelegram  Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([reportDate])
}

// ─── Variant Price Analytics (materialized view per variant) ────
model VariantPriceAnalytics {
  id                  String   @id @default(cuid())
  variantId           String   @unique
  
  // Current market state
  lowestCurrentPrice  Float?   // lowest active listing price right now
  top3AveragePrice    Float?   // average of top 3 cheapest active listings
  marketAveragePrice  Float?   // average of ALL active listings
  medianPrice         Float?   // median price across retailers
  priceSpread         Float?   // max - min price
  activeListingCount  Int      @default(0)
  
  // Historical metrics
  allTimeLowest       Float?
  allTimeHighest      Float?
  avg7d               Float?
  avg30d              Float?
  avg90d              Float?
  lowest7d            Float?
  lowest30d           Float?
  
  // Trend & volatility
  trendDirection      String   @default("unknown") // rising, falling, stable
  volatilityScore     Float?   // standard deviation / mean * 100
  priceChangePercent7d  Float? // % change over 7 days
  priceChangePercent30d Float? // % change over 30 days
  
  // Deal intelligence
  dealProbability     Float?   @default(0) // 0-100, how likely a deal exists now
  bestRetailerSlug    String?
  bestRetailerName    String?
  bestRetailerPrice   Float?
  secondBestSlug      String?
  secondBestPrice     Float?
  savingsVsAverage    Float?   // how much cheaper vs market average
  
  computedAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([dealProbability])
  @@index([computedAt])
}

// ─── Günlük Fiyat Özeti (Aggregated Daily Stats) ────────────────
model PriceDailyStats {
  id          String   @id @default(cuid())
  listingId   String
  date        DateTime @db.Date
  minPrice    Float
  maxPrice    Float
  avgPrice    Float
  openPrice   Float    // First price of the day
  closePrice  Float    // Last price of the day
  sampleCount Int      @default(1)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId])
  @@index([date])
}

// ─── V2 Cross-Cycle Market Snapshot Cache ───────────────────────
// Persists fetchGlobalMarketSnapshot results across worker restarts / multi-instance deployments.
// Key format: "{familyId}:{storageGb}". TTL enforced in code (read-time freshness check).
model MarketSnapshotCache {
  key       String   @id
  data      Json
  ts        DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ts])
}

// ─── Pulse Protocol: Scheduler Cycle Counter (singleton) ────────
// Monotonically incremented once per scheduler run. Listings store the
// absolute cycle after which they become eligible again (`skipUntilCycle`).
// This avoids the N-row UPDATE-per-cycle that a decrementing counter would need.
model SchedulerState {
  id           String   @id @default("default")
  currentCycle Int      @default(0)
  updatedAt    DateTime @updatedAt
}

// ─── Telegram Feedback (community RL loop) ───────────────────────
// Each inline-button click from a deal alert is recorded here. The aggregator
// reads this table to (a) flag ghost listings after 3+ "stok yok" votes in 10min,
// (b) adjust Retailer.confidenceScore on "alabildim" / "kötü fiyat".
//
// Unique constraint on (listingId, chatId, button) makes repeated clicks idempotent —
// a user can only count once per button per listing.
model TelegramFeedbackEvent {
  id            String   @id @default(cuid())
  listingId     String
  chatId        String   // Telegram chat id who voted
  button        TelegramFeedbackButton
  messageId     Int?     // original deal-alert message id (for potential edit)
  variantId     String?  // denorm for fast margin override lookups
  retailerSlug  String?  // denorm for confidence score updates
  createdAt     DateTime @default(now())

  @@unique([listingId, chatId, button])
  @@index([listingId, createdAt])
  @@index([button, createdAt])
  @@index([retailerSlug, button, createdAt])
}

enum TelegramFeedbackButton {
  GOT_IT          // ✅ ALABİLDİM
  OUT_OF_STOCK    // ❌ STOK YOK / HATALI
  GOOD_PRICE      // 🔥 GÜZEL FİYAT
  BAD_PRICE       // 💩 KÖTÜ FİYAT
}
